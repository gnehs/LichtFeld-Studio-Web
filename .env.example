PORT=3000
NODE_ENV=production
SESSION_SECRET=change-me
ADMIN_PASSWORD_HASH=$2b$10$replace_with_bcrypt_hash

LFS_REPO=https://github.com/MrNeRF/LichtFeld-Studio.git
LFS_REF=master
LFS_BIN_PATH=/opt/lichtfeld/bin/LichtFeld-Studio
LFS_DEFAULT_LOG_LEVEL=info
TIMELAPSE_MIN_FREE_GB=5
DISK_GUARD_INTERVAL_MS=15000

DATA_ROOT=/data
DATASETS_DIR=/data/datasets
OUTPUTS_DIR=/data/outputs
DB_PATH=/data/db/app.db
LOGS_DIR=/data/logs
DATASET_ALLOWED_ROOTS=/data/datasets
